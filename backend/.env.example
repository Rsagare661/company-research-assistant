# Optional server-side fallback keys (only used if the client doesn't supply its own).
# Leave blank if every user brings their own keys via the sidebar UI.
OPENROUTER_API_KEY=
SERPER_API_KEY=

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Crawling behavior
MAX_PAGES_TO_CRAWL=8
CRAWL_TIMEOUT_SECONDS=10
MAX_CONTENT_CHARS_PER_PAGE=6000

# Cache TTL for repeated research on the same company
CACHE_TTL_SECONDS=3600

# Default model shown in the UI dropdown
DEFAULT_AI_MODEL=anthropic/claude-sonnet-4.5
